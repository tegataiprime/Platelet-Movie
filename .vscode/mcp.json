{
  "servers": {
    "github-agentic-workflows": {
      "command": "gh",
      "args": [
        "aw",
        "mcp-server"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ]
    },
/*     "doppler": {
      "command": "npx",
      "args": [
        "-y",
        "@dopplerhq/mcp-server"
      ],
      "env": {
        "DOPPLER_TOKEN": "${DOPPLER_TOKEN}"
      }
    }, */
    "tmdb": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-tmdb"
      ],
      "env": {
        "TMDB_API_KEY": "${TMDB_API_KEY}"
      }
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_CLOUD_URL",
        "-e",
        "SONARQUBE_IDE_PORT",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_ORG": "tegataiprime",
        "SONARQUBE_CLOUD_URL": "https://sonarcloud.io",
        "SONARQUBE_TOKEN": "${SONAR_TOKEN}",
        "SONARQUBE_IDE_PORT": "64120"
      }
    }
  }
}